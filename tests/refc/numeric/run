. ../../testutils.sh

# Numeric edge-case tests: bounds, overflow wrapping, large Integer (GMP),
# and IEEE 754 Double special values (Inf, NaN).
idris2 --cg refc -o refc_numeric TestNumeric.idr
# Normalise NaN: some platforms print "-nan" for 0.0/0.0; treat as "nan".
$VALGRIND ./build/exec/refc_numeric | sed 's/^-nan$/nan/'
